[user]
    name = Chayaphol Prapaipornlert
    email = chayaphol.pr@gmail.com

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[pull]
    rebase = false

[fetch]
    prune = true

[merge]
    conflictstyle = zdiff3

[core]
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[color]
    ui = auto

[delta]
    navigate = true
    syntax-theme = ansi
    line-numbers = true
    features = decorations

[delta "decorations"]
    file-style = yellow
    file-decoration-style = none
    hunk-header-decoration-style = blue box
